<IfModule mod_rewrite.c>
    RewriteEngine On

    # Apache/mod_php does not populate $_SERVER['HTTP_AUTHORIZATION'] by default,
    # which breaks Sanctum's Bearer-token auth (Request::bearerToken() reads that
    # superglobal, not getallheaders()). Forward it explicitly.
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^((?s).*)$ index.php?_url=/$1 [QSA,L]
</IfModule>

# Cache versioned assets (app.js?id=xxx) for 1 year — safe because the ?id hash changes on every build
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>